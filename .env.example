# ─── AI Providers (at least one required) ─────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api-key
GEMINI_API_KEY=your_gemini_key
OPENROUTER_API_KEY=sk-or-your_openrouter_key

# Which provider to prefer: "claude", "openrouter", or "gemini" (default: gemini)
AI_PROVIDER=gemini

# ─── Keyword Research ─────────────────────────────────────────────────────────
AHREFS_API_KEY=your_ahrefs_key
SEMRUSH_API_KEY=your_semrush_key

# ─── Google Search Console ─────────────────────────────────────────────────────
# SeoFlow uses Application Default Credentials (ADC) for live GSC data.
# No key needed here — auth is handled by gcloud CLI on your machine.
#
# One-time setup:
#   gcloud auth application-default login \
#     --scopes=https://www.googleapis.com/auth/webmasters.readonly
#
# The site property is read from seoflow.config.json → "siteUrl".
# Override here if your GSC property uses "sc-domain:" format:
#   GSC_SITE_URL=sc-domain:yourdomain.com
#
# GSC_SITE_URL=

# ─── SEO Data ─────────────────────────────────────────────────────────────────
NEURONWRITER_API_KEY=n-your_neuronwriter_key
NEURONWRITER_PROJECT_ID=your_project_id

# ─── Image Sources (optional) ─────────────────────────────────────────────────
PEXELS_API_KEY=your_pexels_key
UNSPLASH_API_KEY=your_unsplash_key
